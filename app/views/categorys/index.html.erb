<p style="color: green"><%= notice %></p>

<% content_for :title, "Categorys" %>

<h1>Categorys</h1>

<div id="categorys">
  <% @categorys.each do |category| %>
    <%= render category %>
    <p>
      <%= link_to "Show this category", category %>
    </p>
  <% end %>
</div>

<%= link_to "New category", new_category_path %>
